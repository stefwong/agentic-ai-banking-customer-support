modules = ["python-3.11"]

[agent]
expertMode = true

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8501
externalPort = 3000

[nix]
packages = ["dig"]

[deployment]
deploymentTarget = "cloudrun"
run = ["streamlit", "run", "app.py", "--server.port", "8080", "--server.address", "0.0.0.0", "--server.enableCORS", "false", "--server.headless", "true"]
